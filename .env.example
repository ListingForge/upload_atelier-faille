# --- Public-facing URL (where this app is reachable) ---
# Used to build OAuth redirect URLs. Must match the App-URL / redirect URL
# you configured in the Shopify Dev Dashboard.
APP_URL=https://upload.atelier-faille.de

# --- Basic Auth (protects the whole app from public access) ---
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# --- Shopify ---
SHOPIFY_API_KEY=                # Client-ID from Dev Dashboard
SHOPIFY_API_SECRET=             # Client Secret (shpss_...) from Dev Dashboard
SHOPIFY_SCOPES=read_products,write_products,read_product_listings,read_files,write_files,read_inventory,write_inventory,read_publications,write_publications
SHOPIFY_STORE=                  # e.g. nvh6nq-0w.myshopify.com
SHOPIFY_ADMIN_TOKEN=            # filled automatically after OAuth install

# --- Printify ---
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

# --- Optional: Google Gemini ---
GEMINI_API_KEY=
